# ── Database ──
# SQLite (default — no setup needed)
DATABASE_URL=./data/wybe.db

# ── LLM Provider ──
# Mode: 'local' (Ollama) or 'cloud' (Anthropic Claude)
# Default: 'local' if no ANTHROPIC_API_KEY, 'cloud' if key is set
LLM_PROVIDER_MODE=local

# Cloud mode (optional — only needed for cloud mode)
ANTHROPIC_API_KEY=

# Local mode — Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:14b
OLLAMA_FAST_MODEL=qwen3:8b
OLLAMA_VISION_MODEL=llava:13b

# ── Voice (optional) ──
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# Voice gateway (for ElevenLabs integration)
WYBE_GATEWAY_API_KEY=
WYBE_GATEWAY_USER_ID=local-user

# ── Tools (optional) ──
BRAVE_SEARCH_API_KEY=
OPENAI_API_KEY=
FIRECRAWL_API_KEY=
